@model ElectricStore_Project.Models.Supplier

@{
    ViewData["Title"] = "Thêm Mới Nhà Cung Cấp";
}

<div class="container mt-4" style="max-width: 720px;">
    <div class="mb-4">
        <h2 class="mb-1 text-primary fw-bold">Thêm Mới Nhà Cung Cấp</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a></li>
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Supplier" asp-action="Index">Nhà cung cấp</a></li>
                <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
            </ol>
        </nav>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label small fw-semibold text-secondary">Tên nhà cung cấp <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control py-2 focus-ring" placeholder="Nhập tên nhà cung cấp mới..." required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label small fw-semibold text-secondary">Địa chỉ</label>
                    <input asp-for="Address" class="form-control py-2 focus-ring" placeholder="Nhập địa chỉ..." />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label small fw-semibold text-secondary">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control py-2 focus-ring" placeholder="Nhập số điện thoại..." />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label small fw-semibold text-secondary">Email</label>
                        <input asp-for="Email" type="email" class="form-control py-2 focus-ring" placeholder="Nhập email..." />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-medium">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold shadow-sm">
                        <i class="bi bi-plus-circle me-1"></i> Thêm mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .focus-ring:focus {
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
    }
</style>
