@model ElectricStore_Project.Models.Country

@{
    ViewData["Title"] = "Chỉnh Sửa Quốc Gia";
}

<div class="container mt-4" style="max-width: 640px;">
    <div class="mb-4">
        <h2 class="mb-1 text-primary fw-bold">Chỉnh Sửa Quốc Gia</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a></li>
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Country" asp-action="Index">Quốc gia</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa</li>
            </ol>
        </nav>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="Country1" class="form-label small fw-semibold text-secondary">Tên quốc gia <span class="text-danger">*</span></label>
                    <input asp-for="Country1" class="form-control py-2.5 focus-ring" placeholder="Nhập tên quốc gia..." required />
                    <span asp-validation-for="Country1" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-medium">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold shadow-sm">
                        <i class="bi bi-save me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .focus-ring:focus {
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
    }
</style>
