@model IEnumerable<ElectricStore_Project.Models.Country>

@{
    ViewData["Title"] = "Country management page";
}

<h1>@ViewData["Title"]</h1>
<div>
<div>
    <a href="@Url.Action("Create", "Country")" class="btn btn-primary">Thêm mới quốc gia</a>
</div>
@foreach (var item in Model)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@item.Country1</h5>
            <a href="@Url.Action("Edit", "Country", new { id = item.Id })" class="btn btn-primary">Edit</a>
            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa quốc gia này không?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
}
</div>
