@model ElectricStore_Project.DTOs.Products.ProductDisplayDTO

@{
    ViewData["Title"] = Model.Name + " - Chi Tiết Sản Phẩm";
    var defaultImage = Model.ImageList != null && Model.ImageList.Any() ? Model.ImageList[0] : "baner.png";
}

<div class="container mt-5">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="bi bi-house-door-fill me-1"></i>Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">@Model.Category</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- LEFT: Image Slider Gallery & Zoom -->
        <div class="col-md-6 col-lg-5">
            <!-- Main Product Image Frame -->
            <div class="position-relative overflow-hidden rounded-4 border bg-white shadow-sm main-image-frame mb-3">
                @if (!string.IsNullOrEmpty(Model.IstallmentTag))
                {
                    <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-3 px-3 py-2 fw-bold rounded-pill" style="z-index: 10;">
                        @Model.IstallmentTag
                    </span>
                }
                
                <!-- Main Image wrapper for hover-zoom -->
                <div class="main-image-container cursor-pointer" onclick="openLightbox()">
                    <img id="main-product-image" src="@Url.Content("~/img/" + defaultImage)" class="img-fluid w-100 h-100 object-fit-contain p-4" alt="@Model.Name" style="transition: opacity 0.15s ease;" />
                </div>

                <!-- Navigation arrows (Hidden if <= 1 image) -->
                @if (Model.ImageList != null && Model.ImageList.Count > 1)
                {
                    <button type="button" class="btn btn-light rounded-circle shadow-sm position-absolute top-50 start-0 translate-middle-y ms-3 nav-gallery-btn" onclick="slidePrev()">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button type="button" class="btn btn-light rounded-circle shadow-sm position-absolute top-50 end-0 translate-middle-y me-3 nav-gallery-btn" onclick="slideNext()">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                }
                
                <!-- Zoom Indicator Hint -->
                <span class="position-absolute bottom-0 end-0 m-3 bg-dark bg-opacity-50 text-white rounded px-2 py-1 small" style="z-index: 2; pointer-events: none;">
                    <i class="bi bi-zoom-in me-1"></i> Nhấn để phóng to
                </span>
            </div>

            <!-- Image Thumbnails Grid -->
            @if (Model.ImageList != null && Model.ImageList.Count > 1)
            {
                <div class="row g-2 justify-content-center">
                    @for (int idx = 0; idx < Model.ImageList.Count; idx++)
                    {
                        var imgPath = Model.ImageList[idx];
                        <div class="col-2.5">
                            <div class="thumbnail-wrapper rounded-3 border bg-white overflow-hidden @(idx == 0 ? "active-thumb" : "")" 
                                 onclick="setMainImage('@Url.Content("~/img/" + imgPath)', @idx)">
                                <img src="@Url.Content("~/img/" + imgPath)" class="img-fluid w-100 h-100 object-fit-contain p-1" alt="Ảnh nhỏ @idx" />
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- RIGHT: Product Details Info -->
        <div class="col-md-6 col-lg-7">
            <!-- Brand & Rating Header -->
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-semibold border border-primary border-opacity-10">
                    <i class="bi bi-tag-fill me-1"></i>@Model.Brand
                </span>
                <div class="d-flex align-items-center text-warning gap-1 small fw-semibold ms-2">
                    <span class="text-dark small">@Model.Rating</span>
                    <i class="bi bi-star-fill"></i>
                    <span class="text-secondary small">(@Model.SalceCount đã bán)</span>
                </div>
            </div>

            <!-- Product Title -->
            <h1 class="h2 fw-bold text-dark mb-3">@Model.Name</h1>

            <!-- Pricing Box -->
            <div class="p-3 rounded-4 bg-light mb-4 border d-flex align-items-baseline gap-3">
                <span class="h2 fw-extrabold text-danger mb-0">@Model.SalePrice.ToString("N0") ₫</span>
                @if (Model.OriginalPrice > Model.SalePrice)
                {
                    <span class="text-muted text-decoration-line-through fs-5">@Model.OriginalPrice.ToString("N0") ₫</span>
                    <span class="badge bg-danger rounded-pill px-2.5 py-1 small">
                        Giảm @(((1 - (double)Model.SalePrice / (double)Model.OriginalPrice) * 100).ToString("0"))%
                    </span>
                }
            </div>

            <!-- Core Specs Table -->
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <div class="border rounded-3 p-3 bg-white h-100">
                        <div class="small text-secondary fw-semibold mb-1">Xuất xứ / Sản xuất</div>
                        <div class="fw-bold text-dark"><i class="bi bi-globe me-2 text-info"></i>@Model.MadeIn</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border rounded-3 p-3 bg-white h-100">
                        <div class="small text-secondary fw-semibold mb-1">Nhà cung cấp</div>
                        <div class="fw-bold text-dark"><i class="bi bi-building me-2 text-primary"></i>@Model.SupplierName</div>
                    </div>
                </div>
            </div>

            <!-- Free Gifts Card -->
            @if (!string.IsNullOrEmpty(Model.GiftInfo))
            {
                <div class="card border-success border-opacity-25 rounded-4 bg-success bg-opacity-5 mb-4 shadow-none">
                    <div class="card-body p-3 d-flex align-items-center gap-3">
                        <div class="bg-success rounded-circle p-2 text-white d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                            <i class="bi bi-gift-fill fs-5"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold text-success mb-1">Quà tặng ưu đãi đi kèm</h6>
                            <p class="text-secondary small mb-0 fw-medium">@Model.GiftInfo</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Inventory Status & Add to Cart -->
            <div class="mb-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="fw-semibold text-secondary">Tình trạng kho hàng:</span>
                    @if (Model.StockQuantity > 0)
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1.5 fw-bold">
                            <i class="bi bi-check-circle-fill me-1"></i>Còn hàng (@Model.StockQuantity)
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-1.5 fw-bold">
                            <i class="bi bi-x-circle-fill me-1"></i>Hết hàng
                        </span>
                    }
                </div>
            </div>

            <form asp-controller="Cart" asp-action="Add" method="post">
                <input type="hidden" name="productId" value="@Model.Id" />
                
                @if (Model.StockQuantity > 0)
                {
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <label for="quantity-val" class="fw-semibold text-secondary mb-0">Số lượng:</label>
                        <div class="qty-input-group d-flex align-items-center" style="max-width: 130px; border: 1px solid #ced4da; border-radius: 30px; overflow: hidden; background-color: #ffffff; padding: 2px;">
                            <button type="button" class="qty-btn" id="btn-minus">-</button>
                            <input type="number" name="quantity" id="quantity-val" class="qty-num text-center" value="1" min="1" max="@Model.StockQuantity" readonly />
                            <button type="button" class="qty-btn" id="btn-plus">+</button>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <a href="/Home/Index" class="btn btn-lg btn-outline-secondary rounded-pill px-4 py-3 fw-semibold" style="font-size: 14.5px;">
                            ← Quay lại trang chủ
                        </a>
                        <button type="submit" class="btn btn-lg btn-primary rounded-pill px-5 py-3 fw-bold d-flex align-items-center gap-2 shadow-sm hover-transform" style="font-size: 14.5px;">
                            <i class="bi bi-cart-plus-fill fs-5"></i> THÊM VÀO GIỎ HÀNG
                        </button>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-3 mt-4">
                        <a href="/Home/Index" class="btn btn-lg btn-outline-secondary rounded-pill px-4 py-3 fw-semibold" style="font-size: 14.5px;">
                            ← Quay lại trang chủ
                        </a>
                        <button type="button" class="btn btn-lg btn-secondary rounded-pill px-5 py-3 fw-bold" style="font-size: 14.5px;" disabled>
                            SẢN PHẨM TẠM HẾT HÀNG
                        </button>
                    </div>
                }
            </form>
        </div>

        <!-- FULL WIDTH: Description -->
        <div class="col-12 mt-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-4 border-bottom border-light">
                    <h4 class="mb-0 fw-bold text-dark d-flex align-items-center">
                        <i class="bi bi-file-text text-primary me-2"></i> Chi Tiết & Mô Tả Sản Phẩm
                    </h4>
                </div>
                <div class="card-body p-4 text-secondary leading-relaxed" style="line-height: 1.8;">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                    }
                    else
                    {
                        <span class="text-muted italic">Mô tả sản phẩm đang được cập nhật...</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Premium Lightbox Modal for Zoom Image Feature -->
<div id="lightboxModal" class="modal fade" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 bg-dark bg-opacity-95 shadow-none rounded-0">
            <div class="modal-header border-0 p-3 position-absolute top-0 end-0" style="z-index: 1050;">
                <button type="button" class="btn-close btn-close-white fs-4" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 d-flex align-items-center justify-content-center overflow-hidden position-relative" style="min-height: 80vh;">
                <!-- Lightbox Image with zooming state -->
                <img id="lightbox-image" src="" class="img-fluid object-fit-contain cursor-zoom-in" style="max-height: 90vh; max-width: 90vw; transition: transform 0.25s ease;" onclick="toggleLightboxZoom()" alt="Hình ảnh phóng to" />
                
                <!-- Zoom State HUD Indicator -->
                <span class="position-absolute bottom-0 text-white bg-black bg-opacity-70 rounded-pill px-3 py-1.5 small mb-4" style="pointer-events: none;">
                    <i class="bi bi-search me-1"></i> Click vào ảnh để phóng to/thu nhỏ thêm
                </span>
            </div>
        </div>
    </div>
</div>

<style>
    /* Slider Frame Gallery Styles */
    .main-image-frame {
        height: 420px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #ffffff;
    }

    .main-image-container {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    /* Slick Micro Hover Zoom */
    .main-image-container img {
        transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .main-image-container:hover img {
        transform: scale(1.06);
    }

    .nav-gallery-btn {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.8;
        transition: all 0.2s;
        border: 1px solid rgba(0,0,0,0.06) !important;
    }
    .nav-gallery-btn:hover {
        opacity: 1;
        background-color: #0d6efd !important;
        color: #ffffff !important;
    }

    /* Interactive Thumbnails */
    .thumbnail-wrapper {
        width: 80px;
        height: 80px;
        cursor: pointer;
        padding: 4px;
        transition: all 0.22s;
        border: 1px solid #dee2e6;
    }
    .thumbnail-wrapper:hover {
        border-color: #0d6efd !important;
        transform: scale(1.04);
    }
    .active-thumb {
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15) !important;
    }

    .col-2.5 {
        width: 20%;
        max-width: 90px;
    }

    .qty-btn {
        background: none;
        border: none;
        width: 38px;
        height: 38px;
        font-weight: bold;
        color: #5f6368;
        outline: none;
        transition: background-color 0.2s;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .qty-btn:hover {
        background-color: #f1f3f4;
    }

    .qty-num {
        border: none;
        width: 50px;
        font-weight: 600;
        outline: none;
    }

    .cursor-pointer {
        cursor: pointer;
    }
    .cursor-zoom-in {
        cursor: zoom-in;
    }
    .cursor-zoom-out {
        cursor: zoom-out;
    }

    .hover-transform {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-transform:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(13, 110, 253, 0.2) !important;
    }
    .animate-transition {
        transition: transform 0.25s ease !important;
    }
</style>

<script>
    // In-memory images list from C# Model
    const imageList = @Html.Raw(Json.Serialize(Model.ImageList));
    let currentImageIndex = 0;

    // Changes the active main display image
    window.setMainImage = function(src, index) {
        currentImageIndex = index;
        const mainImg = document.getElementById("main-product-image");
        if (mainImg) {
            mainImg.style.opacity = 0;
            setTimeout(() => {
                mainImg.src = src;
                mainImg.style.opacity = 1;
            }, 150);
        }

        // Highlight thumbnail border
        document.querySelectorAll(".thumbnail-wrapper").forEach((el, idx) => {
            if (idx === index) {
                el.classList.add("active-thumb");
            } else {
                el.classList.remove("active-thumb");
            }
        });
    };

    // Slider transitions
    window.slidePrev = function() {
        if (imageList && imageList.length > 1) {
            let nextIndex = currentImageIndex - 1;
            if (nextIndex < 0) nextIndex = imageList.length - 1;
            const fullSrc = '@Url.Content("~/img/")' + imageList[nextIndex];
            setMainImage(fullSrc, nextIndex);
        }
    };

    window.slideNext = function() {
        if (imageList && imageList.length > 1) {
            let nextIndex = currentImageIndex + 1;
            if (nextIndex >= imageList.length) nextIndex = 0;
            const fullSrc = '@Url.Content("~/img/")' + imageList[nextIndex];
            setMainImage(fullSrc, nextIndex);
        }
    };

    // Open Lightbox Zoom Modal
    window.openLightbox = function() {
        const currentSrc = document.getElementById("main-product-image").src;
        document.getElementById("lightbox-image").src = currentSrc;
        
        // Reset lightbox zoom state
        const lightboxImg = document.getElementById("lightbox-image");
        lightboxImg.style.transform = "scale(1)";
        lightboxImg.className = "img-fluid object-fit-contain cursor-zoom-in";
        isLightboxZoomed = false;

        const myModal = new bootstrap.Modal(document.getElementById('lightboxModal'));
        myModal.show();
    };

    // Double/Toggle Lightbox Zoom-In Lens magnification
    let isLightboxZoomed = false;
    window.toggleLightboxZoom = function() {
        const lightboxImg = document.getElementById("lightbox-image");
        if (!isLightboxZoomed) {
            lightboxImg.style.transform = "scale(1.8)";
            lightboxImg.className = "img-fluid object-fit-contain cursor-zoom-out animate-transition";
            isLightboxZoomed = true;
        } else {
            lightboxImg.style.transform = "scale(1)";
            lightboxImg.className = "img-fluid object-fit-contain cursor-zoom-in animate-transition";
            isLightboxZoomed = false;
        }
    };

    // Form logic quantity buttons
    document.addEventListener("DOMContentLoaded", function () {
        const btnMinus = document.getElementById("btn-minus");
        const btnPlus = document.getElementById("btn-plus");
        const inputVal = document.getElementById("quantity-val");
        const maxStock = parseInt("@Model.StockQuantity" || "0");

        if (btnMinus && btnPlus && inputVal) {
            btnMinus.addEventListener("click", function () {
                let current = parseInt(inputVal.value) || 1;
                if (current > 1) {
                    inputVal.value = current - 1;
                }
            });

            btnPlus.addEventListener("click", function () {
                let current = parseInt(inputVal.value) || 1;
                if (current < maxStock) {
                    inputVal.value = current + 1;
                }
            });
        }
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
        didOpen: (toast) => {
            toast.addEventListener('mouseenter', Swal.stopTimer)
            toast.addEventListener('mouseleave', Swal.resumeTimer)
        }
    });

    @if (TempData["SuccessMessage"] != null)
    {
        <text>
            Toast.fire({
                icon: 'success',
                title: '@TempData["SuccessMessage"]'
            });
        </text>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <text>
            Toast.fire({
                icon: 'error',
                title: '@TempData["ErrorMessage"]'
            });
        </text>
    }
</script>