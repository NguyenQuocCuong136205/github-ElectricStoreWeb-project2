@model ElectricStore_Project.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">

    <h2 class="mb-3">@Model.Name</h2>

    <div class="row">
        <!-- Hình ảnh -->
        <div class="col-md-5">
            <img src="@(Model.ProductImages.FirstOrDefault()?.Img ?? "/images/no-image.png")"
                 class="img-fluid rounded shadow"
                 alt="@Model.Name" />
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-7">

            <h4 class="text-danger">
                @($"{Model.OriginalPrice ?? 0:N0} ₫")
            </h4>

            <hr />

            <p><strong>Mô tả:</strong></p>
            <p>@Model.Description</p>

            <p>
                <strong>Danh mục:</strong>
                @Model.Category?.Name
            </p>

            <p>
                <strong>Tồn kho:</strong>
                @if (Model.StockQuantity > 0)
                {
                    <span class="text-success">Còn hàng (@Model.StockQuantity)</span>
                }
                else
                {
                    <span class="text-danger">Hết hàng</span>
                }
            </p>

            <div class="mt-3">
                <a href="/Home/Index" class="btn btn-secondary">
                    ← Quay lại
                </a>

                <button class="btn btn-primary">
                    Thêm vào giỏ hàng
                </button>
            </div>

        </div>
    </div>

</div>