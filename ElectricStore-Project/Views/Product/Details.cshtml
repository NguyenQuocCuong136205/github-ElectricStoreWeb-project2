@model ElectricStore_Project.Models.Product

@{
    ViewData["Title"] = "Product Details";
}


<!DOCTYPE html>
<html lang="en">
<head>

</head>
<body>
<div class="container mt-4">

    <h2 class="mb-3">@Model.Name</h2>

    <div class="row">
        <!-- Hình ảnh -->
        <div class="col-md-5">
                <img src="https://images.unsplash.com/photo-1546868871-7041f2a55e12?auto=format&fit=crop&q=80&w=400" )"
                 class="img-fluid rounded shadow"
                 alt="@Model.Name" />
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-7">

            <h4 class="text-danger">
                @($"{Model.SalePrice ?? 0:N0} ₫")
            </h4>

            <hr />

            <p><strong>Mô tả:</strong></p>
            <p>@Model.Description</p>

            <p>
                <strong>Danh mục:</strong>
                @Model.Category?.Name
            </p>

            <p>
                <strong>Tồn kho:</strong>
                @if (Model.StockQuantity > 0)
                {
                    <span class="text-success">Còn hàng (@Model.StockQuantity)</span>
                }
                else
                {
                    <span class="text-danger">Hết hàng</span>
                }
            </p>

            <form asp-controller="Cart" asp-action="Add" method="post" class="mt-4">
                <input type="hidden" name="productId" value="@Model.Id" />
                
                @if (Model.StockQuantity > 0)
                {
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <label for="quantity-val" class="fw-semibold text-secondary mb-0" style="font-size: 14.5px;">Số lượng:</label>
                        <div class="qty-input-group d-flex align-items-center" style="max-width: 130px; border: 1px solid #ced4da; border-radius: 30px; overflow: hidden; background-color: #ffffff; padding: 2px;">
                            <button type="button" class="qty-btn" id="btn-minus" style="background:none; border:none; width:35px; height:35px; font-weight:bold; color:#5f6368; outline:none; transition: background-color 0.2s;">-</button>
                            <input type="number" name="quantity" id="quantity-val" class="qty-num text-center" value="1" min="1" max="@Model.StockQuantity" readonly style="border:none; width:50px; font-weight:600; outline:none;" />
                            <button type="button" class="qty-btn" id="btn-plus" style="background:none; border:none; width:35px; height:35px; font-weight:bold; color:#5f6368; outline:none; transition: background-color 0.2s;">+</button>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <a href="/Home/Index" class="btn btn-outline-secondary rounded-pill px-4 py-2.5 fw-semibold" style="font-size: 14.5px;">
                            ← Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2.5 fw-semibold d-flex align-items-center gap-2" style="font-size: 14.5px; box-shadow: 0 4px 12px rgba(13,110,253,0.18); transition: all 0.2s;">
                            <i class="bi bi-cart-plus fs-5"></i> Thêm vào giỏ hàng
                        </button>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-2 mt-4">
                        <a href="/Home/Index" class="btn btn-outline-secondary rounded-pill px-4 py-2.5 fw-semibold" style="font-size: 14.5px;">
                            ← Quay lại
                        </a>
                        <button type="button" class="btn btn-secondary rounded-pill px-4 py-2.5 fw-semibold" style="font-size: 14.5px;" disabled>
                            Hết hàng
                        </button>
                    </div>
                }
            </form>
        </div>

    </div>
</div>

<style>
    .container {
        padding: 10px;
    }
    
    .qty-btn:hover {
        background-color: #f1f3f4;
        border-radius: 50%;
    }
    
    /* Chrome, Safari, Edge, Opera: Remove spin arrows */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const btnMinus = document.getElementById("btn-minus");
        const btnPlus = document.getElementById("btn-plus");
        const inputVal = document.getElementById("quantity-val");
        const maxStock = parseInt("@Model.StockQuantity" || "0");

        if (btnMinus && btnPlus && inputVal) {
            btnMinus.addEventListener("click", function () {
                let current = parseInt(inputVal.value) || 1;
                if (current > 1) {
                    inputVal.value = current - 1;
                }
            });

            btnPlus.addEventListener("click", function () {
                let current = parseInt(inputVal.value) || 1;
                if (current < maxStock) {
                    inputVal.value = current + 1;
                }
            });
        }
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Cấu hình định dạng cửa sổ Toast nhỏ ở góc trên bên phải
        const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000, // Tự động ẩn sau 3 giây
        timerProgressBar: true,
        didOpen: (toast) => {
        toast.addEventListener('mouseenter', Swal.stopTimer)
        toast.addEventListener('mouseleave', Swal.resumeTimer)
        }
        });

        // Kiểm tra xem Server có gửi TempData["SuccessMessage"] về không
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                Toast.fire({
                icon: 'success',
                title: '@TempData["SuccessMessage"]'
                });
            </text>
        }

        // Kiểm tra xem Server có gửi TempData["ErrorMessage"] về không (nếu có dùng)
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
                Toast.fire({
                icon: 'error',
                title: '@TempData["ErrorMessage"]'
                });
            </text>
        }
    </script>
</body>
</html>