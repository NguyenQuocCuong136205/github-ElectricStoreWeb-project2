@model ElectricStore_Project.DTOs.Customers.ShowableCustomerInfor

@{
    ViewData["Title"] = "Thông tin tài khoản - ElectriStore";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Inter', sans-serif;
            color: #333333;
            min-height: 100vh;
        }

        .profile-container {
            max-width: 1100px;
            margin-top: 40px;
            margin-bottom: 40px;
        }

        /* Sidebar styling */
        .sidebar-card {
            background-color: transparent;
            border: none;
        }

        .user-name-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #202124;
        }

        .menu-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-top: 20px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            text-decoration: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            color: #5f6368;
            transition: all 0.2s ease-in-out;
            background-color: transparent;
        }

        .menu-item i {
            font-size: 1.2rem;
            margin-right: 12px;
        }

        /* Menu item active/hover styling according to customer request */
        
        /* 1. Đơn hàng đã mua (Active: Xanh lá, Hover: Xanh lá) */
        .menu-item.active-green,
        .menu-item.btn-green:hover {
            background-color: #e6f4ea;
            color: #137333;
            font-weight: 600;
        }

        /* 2. Thông tin cá nhân (Active: Xanh dương, Hover: Xanh dương) */
        .menu-item.active-blue,
        .menu-item.btn-blue:hover {
            background-color: #e8f0fe;
            color: #1a73e8;
            font-weight: 600;
        }

        /* 3. Mã giảm của bạn (Active: Vàng, Hover: Vàng) */
        .menu-item.active-yellow,
        .menu-item.btn-yellow:hover {
            background-color: #fef7e0;
            color: #b06000;
            font-weight: 600;
        }

        /* Nút đăng xuất */
        .btn-logout {
            display: block;
            width: 100%;
            text-align: center;
            padding: 10px;
            margin-top: 25px;
            background-color: #ffffff;
            color: #ff5722;
            border: 1px solid #ff5722;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-logout:hover {
            background-color: #fbebe6;
            color: #e64a19;
            border-color: #e64a19;
        }

        /* Content area styling */
        .content-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #202124;
            margin-bottom: 20px;
        }

        .info-card {
            background-color: #ffffff;
            border-radius: 8px;
            padding: 24px;
            box-shadow: 0 1px 3px rgba(60,64,67, 0.1), 0 1px 2px rgba(60,64,67, 0.05);
            margin-bottom: 20px;
            border: none;
        }

        .card-sec-title {
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 0.8px;
            color: #5f6368;
            margin-bottom: 16px;
            text-transform: uppercase;
        }

        .edit-link {
            color: #1a73e8;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            margin-left: 10px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .edit-link:hover {
            text-decoration: underline;
        }

        .btn-add-address {
            background-color: #ff5722;
            color: #ffffff;
            border: none;
            border-radius: 6px;
            padding: 12px 32px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: background-color 0.2s;
        }

        .btn-add-address:hover {
            background-color: #e64a19;
        }

        .address-item {
            padding: 12px 0;
            border-bottom: 1px solid #f1f3f4;
        }

        .address-item:last-child {
            border-bottom: none;
        }
    </style>
</head>
<body>

    <div class="container profile-container">
        <div class="row g-4">
            
            <!-- Sidebar bên trái -->
            <div class="col-12 col-md-4 col-lg-3">
                <div class="sidebar-card">
                    <!-- User name -->
                    <div class="px-2 mb-3">
                        <span class="user-name-title">Anh @Model.UserName</span>
                    </div>

                    <!-- Navigation menu -->
                    <div class="menu-list">
                        <!-- 1. Đơn hàng đã mua (Active: Xanh lá, Không active ở trang này) -->
                        <a asp-area="" asp-controller="User" asp-action="PurchasedOrders" class="menu-item btn-green">
                            <i class="bi bi-box-seam"></i>
                            Đơn hàng đã mua
                        </a>

                        <!-- 2. Thông tin cá nhân (Active: Xanh dương trên trang Home này) -->
                        <a href="#" class="menu-item btn-blue active-blue">
                            <i class="bi bi-person-badge"></i>
                            Thông tin cá nhân
                        </a>

                        <!-- 3. Mã giảm của bạn (Active: Vàng, Không active ở trang này) -->
                        <a href="#" class="menu-item btn-yellow">
                            <i class="bi bi-percent"></i>
                            Mã giảm của bạn
                        </a>
                    </div>

                    <!-- Nút Đăng xuất -->
                    <a asp-controller="User" asp-action="Logout" class="btn-logout">
                        Đăng Xuất
                    </a>
                </div>
            </div>

            <!-- Vùng nội dung bên phải -->
            <div class="col-12 col-md-8 col-lg-9">
                <div class="content-title">Thông tin tài khoản</div>

                <!-- Card 1: THÔNG TIN CÁ NHÂN -->
                <div class="info-card">
                    <div class="card-sec-title">Thông tin cá nhân</div>
                    <div class="d-flex align-items-center flex-wrap fs-6 white-space: pre-line;">
                        <ul>
                            <li class="fw-medium text-dark">Tên: @Model.UserName</li>
                            <li class="fw-medium text-dark">Email: @Model.UserEmail</li>
                            <li class="fw-medium text-dark">Số điện thoại: @Model.UserPhoneNumber</li>
                            <li class="fw-medium text-dark">Ngày tạo tài khoản: @Model.CreatedDate</li>
                        </ul>
                        @* <a href="#" class="edit-link ms-3">
                            <i class="bi bi-pencil"></i> Sửa
                        </a> *@
                    </div>
                </div>

                <!-- Card 2: ĐỊA CHỈ NHẬN HÀNG -->
                <div class="info-card">
                    <div class="card-sec-title">Địa chỉ nhận hàng</div>
                    @if (Model.Address != null && Model.Address.Any())
                    {
                        <div class="mb-4">
                            @foreach (var addr in Model.Address)
                            {
                                <div class="address-item d-flex justify-content-between align-items-center py-3">
                                    <div class="d-flex align-items-start">
                                        <i class="bi bi-geo-alt-fill text-danger me-2 mt-1"></i>
                                        <span class="text-dark" id="addressText-@addr.Id">@addr.Address</span>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-primary btn-edit-address-trigger" data-id="@addr.Id" data-address="@addr.Address" style="border-radius: 6px; font-size: 0.85rem; padding: 4px 10px;">
                                            <i class="bi bi-pencil me-1"></i> Sửa
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-delete-address-trigger" data-id="@addr.Id" style="border-radius: 6px; font-size: 0.85rem; padding: 4px 10px;">
                                            <i class="bi bi-trash me-1"></i> Xóa
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    
                    <div class="text-center py-3">
                        <button class="btn-add-address" data-bs-toggle="modal" data-bs-target="#addAddressModal">Thêm địa chỉ mới</button>
                    </div>
                </div>

            </div>

        </div>
    </div>

    <!-- Modal Thêm địa chỉ mới -->
    <div class="modal fade" id="addAddressModal" tabindex="-1" aria-labelledby="addAddressModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
                <div class="modal-header bg-light border-bottom-0 pb-0" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="modal-title fw-bold text-dark" id="addAddressModalLabel">
                        <i class="bi bi-geo-alt-fill text-danger me-2"></i>Thêm địa chỉ mới
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <form id="addAddressForm">
                        <input type="hidden" id="userId" value="@Model.Id" />
                        <div class="mb-3">
                            <label for="newAddressInput" class="form-label fw-semibold text-secondary">Địa chỉ nhận hàng</label>
                            <textarea class="form-control border-2" id="newAddressInput" rows="3" placeholder="Nhập số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố..." required style="border-color: #e0e0e0; resize: none; border-radius: 8px;"></textarea>
                            <div class="invalid-feedback">
                                Vui lòng nhập địa chỉ nhận hàng hợp lệ.
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2" data-bs-dismiss="modal" style="border-radius: 8px; font-weight: 600;">Hủy</button>
                    <button type="button" id="btnSaveAddress" class="btn px-4 py-2 text-white" style="background-color: #ff5722; border-radius: 8px; font-weight: 600; border: none; transition: background-color 0.2s;">
                        Lưu địa chỉ
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Chỉnh sửa địa chỉ -->
    <div class="modal fade" id="editAddressModal" tabindex="-1" aria-labelledby="editAddressModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
                <div class="modal-header bg-light border-bottom-0 pb-0" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h5 class="modal-title fw-bold text-dark" id="editAddressModalLabel">
                        <i class="bi bi-pencil-square text-primary me-2"></i>Chỉnh sửa địa chỉ
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <form id="editAddressForm">
                        <input type="hidden" id="editAddressId" />
                        <div class="mb-3">
                            <label for="editAddressInput" class="form-label fw-semibold text-secondary">Địa chỉ nhận hàng</label>
                            <textarea class="form-control border-2" id="editAddressInput" rows="3" placeholder="Nhập địa chỉ mới..." required style="border-color: #e0e0e0; resize: none; border-radius: 8px;"></textarea>
                            <div class="invalid-feedback">
                                Vui lòng nhập địa chỉ nhận hàng hợp lệ.
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2" data-bs-dismiss="modal" style="border-radius: 8px; font-weight: 600;">Hủy</button>
                    <button type="button" id="btnUpdateAddress" class="btn px-4 py-2 text-white btn-primary" style="border-radius: 8px; font-weight: 600; border: none; transition: background-color 0.2s;">
                        Cập nhật
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <!-- AJAX Script for Adding Address via Modal -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // === XỬ LÝ THÊM ĐỊA CHỈ MỚI ===
            const btnSaveAddress = document.getElementById("btnSaveAddress");
            const newAddressInput = document.getElementById("newAddressInput");
            const userId = document.getElementById("userId").value;
            const addAddressModalEl = document.getElementById('addAddressModal');
            const addAddressModal = new bootstrap.Modal(addAddressModalEl);

            btnSaveAddress.addEventListener("click", async function () {
                const addressVal = newAddressInput.value.trim();
                if (!addressVal) {
                    newAddressInput.classList.add("is-invalid");
                    return;
                }
                newAddressInput.classList.remove("is-invalid");

                btnSaveAddress.disabled = true;
                btnSaveAddress.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang lưu...';

                try {
                    const response = await fetch('/Address/CreateNewAddress', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            userID: parseInt(userId),
                            newAddress: addressVal
                        })
                    });

                    const result = await response.json();
                    if (result.success) {
                        addAddressModal.hide();
                        alert(result.message || "Thêm địa chỉ mới thành công!");
                        location.reload();
                    } else {
                        alert(result.message || "Đã xảy ra lỗi khi thêm địa chỉ.");
                    }
                } catch (error) {
                    console.error("Lỗi AJAX thêm địa chỉ:", error);
                    alert("Không thể kết nối đến máy chủ. Vui lòng thử lại sau.");
                } finally {
                    btnSaveAddress.disabled = false;
                    btnSaveAddress.innerText = 'Lưu địa chỉ';
                }
            });

            addAddressModalEl.addEventListener('hidden.bs.modal', function () {
                newAddressInput.value = '';
                newAddressInput.classList.remove("is-invalid");
            });

            // === XỬ LÝ SỬA ĐỊA CHỈ ===
            const editAddressModalEl = document.getElementById('editAddressModal');
            const editAddressModal = new bootstrap.Modal(editAddressModalEl);
            const editAddressId = document.getElementById("editAddressId");
            const editAddressInput = document.getElementById("editAddressInput");
            const btnUpdateAddress = document.getElementById("btnUpdateAddress");

            // Mở modal sửa địa chỉ khi click nút Sửa
            document.querySelectorAll(".btn-edit-address-trigger").forEach(button => {
                button.addEventListener("click", function () {
                    const id = this.getAttribute("data-id");
                    const address = this.getAttribute("data-address");

                    editAddressId.value = id;
                    editAddressInput.value = address;
                    editAddressInput.classList.remove("is-invalid");

                    editAddressModal.show();
                });
            });

            // Gửi dữ liệu cập nhật
            btnUpdateAddress.addEventListener("click", async function () {
                const addressVal = editAddressInput.value.trim();
                const addressId = editAddressId.value;

                if (!addressVal) {
                    editAddressInput.classList.add("is-invalid");
                    return;
                }
                editAddressInput.classList.remove("is-invalid");

                btnUpdateAddress.disabled = true;
                btnUpdateAddress.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang cập nhật...';

                try {
                    const response = await fetch('/Address/UpdateAddress', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            addressID: parseInt(addressId),
                            userID: parseInt(userId),
                            updatedAddress: addressVal
                        })
                    });

                    const result = await response.json();
                    if (result.success) {
                        editAddressModal.hide();
                        alert(result.message || "Cập nhật địa chỉ thành công!");
                        location.reload();
                    } else {
                        alert(result.message || "Đã xảy ra lỗi khi cập nhật địa chỉ.");
                    }
                } catch (error) {
                    console.error("Lỗi AJAX cập nhật địa chỉ:", error);
                    alert("Không thể kết nối đến máy chủ. Vui lòng thử lại sau.");
                } finally {
                    btnUpdateAddress.disabled = false;
                    btnUpdateAddress.innerText = 'Cập nhật';
                }
            });

            // === XỬ LÝ XÓA ĐỊA CHỈ ===
            document.querySelectorAll(".btn-delete-address-trigger").forEach(button => {
                button.addEventListener("click", async function () {
                    const addressId = this.getAttribute("data-id");

                    if (!confirm("Bạn có chắc chắn muốn xóa địa chỉ này? Thao tác này không thể hoàn tác.")) {
                        return;
                    }

                    // Vô hiệu hóa nút để tránh gửi yêu cầu liên tục
                    this.disabled = true;

                    try {
                        const response = await fetch('/Address/DeleteAddress', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                addressID: parseInt(addressId),
                                userID: parseInt(userId)
                            })
                        });

                        const result = await response.json();
                        if (result.success) {
                            alert(result.message || "Xóa địa chỉ thành công!");
                            location.reload();
                        } else {
                            alert(result.message || "Đã xảy ra lỗi khi xóa địa chỉ.");
                            this.disabled = false;
                        }
                    } catch (error) {
                        console.error("Lỗi AJAX xóa địa chỉ:", error);
                        alert("Không thể kết nối đến máy chủ. Vui lòng thử lại sau.");
                        this.disabled = false;
                    }
                });
            });
        });
    </script>
</body>
</html>
