@model ElectricStore_Project.Models.User

@{
    ViewData["Title"] = "Thông tin tài khoản - ElectriStore";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Inter', sans-serif;
            color: #333333;
            min-height: 100vh;
        }

        .profile-container {
            max-width: 1100px;
            margin-top: 40px;
            margin-bottom: 40px;
        }

        /* Sidebar styling */
        .sidebar-card {
            background-color: transparent;
            border: none;
        }

        .user-name-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #202124;
        }

        .menu-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-top: 20px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            text-decoration: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            color: #5f6368;
            transition: all 0.2s ease-in-out;
            background-color: transparent;
        }

        .menu-item i {
            font-size: 1.2rem;
            margin-right: 12px;
        }

        /* Menu item active/hover styling according to customer request */
        
        /* 1. Đơn hàng đã mua (Active: Xanh lá, Hover: Xanh lá) */
        .menu-item.active-green,
        .menu-item.btn-green:hover {
            background-color: #e6f4ea;
            color: #137333;
            font-weight: 600;
        }

        /* 2. Thông tin cá nhân (Active: Xanh dương, Hover: Xanh dương) */
        .menu-item.active-blue,
        .menu-item.btn-blue:hover {
            background-color: #e8f0fe;
            color: #1a73e8;
            font-weight: 600;
        }

        /* 3. Mã giảm của bạn (Active: Vàng, Hover: Vàng) */
        .menu-item.active-yellow,
        .menu-item.btn-yellow:hover {
            background-color: #fef7e0;
            color: #b06000;
            font-weight: 600;
        }

        /* Nút đăng xuất */
        .btn-logout {
            display: block;
            width: 100%;
            text-align: center;
            padding: 10px;
            margin-top: 25px;
            background-color: #ffffff;
            color: #ff5722;
            border: 1px solid #ff5722;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-logout:hover {
            background-color: #fbebe6;
            color: #e64a19;
            border-color: #e64a19;
        }

        /* Content area styling */
        .content-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #202124;
            margin-bottom: 20px;
        }

        .info-card {
            background-color: #ffffff;
            border-radius: 8px;
            padding: 24px;
            box-shadow: 0 1px 3px rgba(60,64,67, 0.1), 0 1px 2px rgba(60,64,67, 0.05);
            margin-bottom: 20px;
            border: none;
        }

        .card-sec-title {
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 0.8px;
            color: #5f6368;
            margin-bottom: 16px;
            text-transform: uppercase;
        }

        .edit-link {
            color: #1a73e8;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            margin-left: 10px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .edit-link:hover {
            text-decoration: underline;
        }

        .btn-add-address {
            background-color: #ff5722;
            color: #ffffff;
            border: none;
            border-radius: 6px;
            padding: 12px 32px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: background-color 0.2s;
        }

        .btn-add-address:hover {
            background-color: #e64a19;
        }

        .address-item {
            padding: 12px 0;
            border-bottom: 1px solid #f1f3f4;
        }

        .address-item:last-child {
            border-bottom: none;
        }
    </style>
</head>
<body>

    <div class="container profile-container">
        <div class="row g-4">
            
            <!-- Sidebar bên trái -->
            <div class="col-12 col-md-4 col-lg-3">
                <div class="sidebar-card">
                    <!-- User name -->
                    <div class="px-2 mb-3">
                        <span class="user-name-title">Anh @Model.FullName</span>
                    </div>

                    <!-- Navigation menu -->
                    <div class="menu-list">
                        <!-- 1. Đơn hàng đã mua (Active: Xanh lá, Không active ở trang này) -->
                        <a href="#" class="menu-item btn-green">
                            <i class="bi bi-box-seam"></i>
                            Đơn hàng đã mua
                        </a>

                        <!-- 2. Thông tin cá nhân (Active: Xanh dương trên trang Home này) -->
                        <a href="#" class="menu-item btn-blue active-blue">
                            <i class="bi bi-person-badge"></i>
                            Thông tin cá nhân
                        </a>

                        <!-- 3. Mã giảm của bạn (Active: Vàng, Không active ở trang này) -->
                        <a href="#" class="menu-item btn-yellow">
                            <i class="bi bi-percent"></i>
                            Mã giảm của bạn
                        </a>
                    </div>

                    <!-- Nút Đăng xuất -->
                    <a asp-controller="User" asp-action="Logout" class="btn-logout">
                        Đăng Xuất
                    </a>
                </div>
            </div>

            <!-- Vùng nội dung bên phải -->
            <div class="col-12 col-md-8 col-lg-9">
                <div class="content-title">Thông tin tài khoản</div>

                <!-- Card 1: THÔNG TIN CÁ NHÂN -->
                <div class="info-card">
                    <div class="card-sec-title">Thông tin cá nhân</div>
                    <div class="d-flex align-items-center flex-wrap fs-6 white-space: pre-line;">
                        <span class="fw-medium text-dark">Tên: @Model.FullName</span>
                        <span class="fw-medium text-dark">Email: @Model.Email</span>
                        <span class="fw-medium text-dark">Số điện thoại: @Model.Phone</span>
                        <span class="fw-medium text-dark">Ngày tạo tài khoản: @Model.CreateAt</span>
                        @* <a href="#" class="edit-link ms-3">
                            <i class="bi bi-pencil"></i> Sửa
                        </a> *@
                    </div>
                </div>

                <!-- Card 2: ĐỊA CHỈ NHẬN HÀNG -->
                <div class="info-card">
                    <div class="card-sec-title">Địa chỉ nhận hàng</div>
                    
                    @if (Model.Addresses != null && Model.Addresses.Any())
                    {
                        <div class="mb-4">
                            @foreach (var addr in Model.Addresses)
                            {
                                <div class="address-item d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-start">
                                        <i class="bi bi-geo-alt-fill text-danger me-2 mt-1"></i>
                                        <span class="text-dark">@addr.FullAddress</span>
                                    </div>
                                    <a href="#" class="text-secondary text-decoration-none small hover-underline ms-3">Xóa</a>
                                </div>
                            }
                        </div>
                    }
                    
                    <div class="text-center py-3">
                        <button class="btn-add-address">Thêm địa chỉ mới</button>
                    </div>
                </div>

            </div>

        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</body>
</html>
